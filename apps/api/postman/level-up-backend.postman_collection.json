						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{API_URL}}/interviews/{{interviewId}}/report",
							"host": [
								"{{API_URL}}"
							],
							"path": [
								"interviews",
								"{{interviewId}}",
								"report"
