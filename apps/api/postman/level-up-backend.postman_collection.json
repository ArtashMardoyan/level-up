							"raw": "{{API_URL}}/interviews/{{interviewId}}",
							"host": [
								"{{API_URL}}"
							],
							"path": [
								"interviews",
								"{{interviewId}}"
							]
						},
						"description": "Resume payload: { session, history: [{question, result}], current, finished }. Rebuilds the chat from stored answers/feedback up to currentIndex. Captures the current question id into {{questionId}}."
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const res = pm.response.json();",
									"if (res.data && res.data.current) {",
									"    pm.environment.set('questionId', res.data.current.questionId);",
									"}"
								]
							}
						}
					]
				},
				{
