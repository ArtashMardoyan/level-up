						},
						"description": "Final report + per-question review for a completed interview: { report, session, review }. report has overallScore /100, the four rubric averages (correctness/depth/communication/structure), verdict, strengths, weaknesses, recommendations."
					}
				},
				{
					"name": "Start Interview",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{API_URL}}/interviews",
							"host": [
								"{{API_URL}}"
							],
							"path": [
								"interviews"
							]
						},
						"description": "Start a session. Rejects with 409 if the caller already has one in progress. Returns { session, history, current } with the first question. Captures {{interviewId}} and the first {{questionId}}.",
						"body": {
							"mode": "raw",
							"raw": "{\n    \"courseSlug\": \"backend\",\n    \"difficulty\": \"medium\",\n    \"language\": \"en\",\n    \"questionCount\": 3\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const res = pm.response.json();",
									"if (res.data) {",
									"    if (res.data.session) pm.environment.set('interviewId', res.data.session.id);",
									"    if (res.data.current) pm.environment.set('questionId', res.data.current.questionId);",
									"}"
								]
							}
						}
					]
				},
				{
					"name": "Transcribe Answer",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{API_URL}}/interviews/transcribe",
							"host": [
								"{{API_URL}}"
							],
							"path": [
								"interviews",
								"transcribe"
							]
						},
						"description": "Transcribe a recorded voice answer via Whisper. multipart/form-data: audio (file) + optional language (en|ru|hy). Body limit is 25 MB for this route (audio); returns { data: { transcript } }.",
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "audio",
									"type": "file",
									"src": []
								},
								{
									"key": "language",
									"value": "ru",
									"type": "text",
									"description": "Interview language (en|ru|hy) — pins Whisper to the spoken language; other values auto-detect."
								}
							]
						}
					}
				},
				{
					"name": "Submit Answer",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{API_URL}}/interviews/{{interviewId}}/answers/{{questionId}}",
							"host": [
								"{{API_URL}}"
							],
							"path": [
								"interviews",
								"{{interviewId}}",
								"answers",
								"{{questionId}}"
							]
						},
						"description": "Submit one answer. Evaluated on submit via the AI layer (unless skipped) and returns { result, next, finished }. result carries score + rubric + feedback (shown as the AI's chat reply). Captures the next {{questionId}}. Set \"skipped\": true to skip (scores 0, no AI call).",
						"body": {
							"mode": "raw",
							"raw": "{\n    \"answer\": \"Dependency injection is a pattern where a component receives its dependencies from the outside instead of creating them, which improves testability and decoupling.\",\n    \"skipped\": false\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const res = pm.response.json();",
									"if (res.data && res.data.next) {",
									"    pm.environment.set('questionId', res.data.next.questionId);",
									"}"
								]
							}
						}
					]
				},
				{
					"name": "Submit Answer (stream, SSE)",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{API_URL}}/interviews/{{interviewId}}/answers/{{questionId}}/stream",
							"host": [
								"{{API_URL}}"
							],
							"path": [
								"interviews",
								"{{interviewId}}",
								"answers",
								"{{questionId}}",
								"stream"
							]
						},
						"description": "Streaming (Server-Sent Events) variant of Submit Answer (docs/product/ai-chat). Same body as Submit Answer. Responds with `text/event-stream`, not JSON: an `event: done` frame carries `{ next, finished }` (the next question, or finished=true), or an `event: error` frame carries `{ message, recoverable }`. The next question streams as `delta` frames (token-by-token from OpenAI), then a `done` frame carries the canonical turn. The answer is persisted immediately and graded off the critical path (inline only on the final question). Pre-stream failures (auth/validation/not-found) still return a normal JSON `{ error }`. Use Postman's SSE view to read the frames; the questionId capture that the JSON Submit Answer does is not possible here because the body is an event stream.",
						"body": {
							"mode": "raw",
							"raw": "{\n    \"answer\": \"Dependency injection is a pattern where a component receives its dependencies from the outside instead of creating them, which improves testability and decoupling.\",\n    \"skipped\": false\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						}
					}
				},
