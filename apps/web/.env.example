# apps/web (frontend) — environment variables.
# Vite inlines VITE_* vars at build time. Copy to `.env` and fill in. No secrets here.

# Backend API base URL (the Go api). Local: the apps/api server; prod: App Runner URL.
VITE_API_URL="http://localhost:3000"

# Public S3 bucket base URL for pre-generated question audio (MP3s). Optional —
# absent → the app falls back to browser speech synthesis.
VITE_S3_BUCKET_URL="https://levelup-6824c358.s3.us-east-2.amazonaws.com"

# Feature flag: marketing site at root (root -> Home, app at #interview). "true" | "false".
VITE_MARKETING="false"

# Feature flag: AI interview chat streaming (SSE). "true" | "false".
VITE_STREAMING_CHAT="false"
